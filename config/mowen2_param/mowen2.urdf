<?xml version="1.0" encoding="utf-8"?>
<!-- mowen2 - mecanum wheel robot URDF (static version) -->
<robot name="mowen2">

  <link name="base_footprint"/>

  <link name="base_link">
    <inertial>
      <origin xyz="-0.0718509386127855 0.00738215784490594 0.119676355791491" rpy="0 0 0"/>
