<?xml version='1.0'?>
<sdf version='1.6'>
  <world name='arena_6x8_empty'>
    <!-- 全局光照系统 -->
    <light name='sun' type='directional'>
      <cast_shadows>1</cast_shadows>
      <pose frame=''>0 0 10 0 -0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <!-- 地面平面 -->
    <model name='ground_plane'>
      <static>1</static>
      <link name='link'>
        <collision name='collision'>
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>100 100</size>
            </plane>
          </geometry>
          <surface>
            <contact>
              <collide_bitmask>65535</collide_bitmask>
              <ode/>
            </contact>
            <friction>
              <ode>
                <mu>100</mu>
                <mu2>50</mu2>
              </ode>
              <torsional>
                <ode/>
              </torsional>
            </friction>
            <bounce/>
          </surface>
          <max_contacts>10</max_contacts>
        </collision>
        <visual name='visual'>
          <cast_shadows>0</cast_shadows>
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>100 100</size>
            </plane>
          </geometry>
          <material>
            <script>
              <uri>file://media/materials/scripts/gazebo.material</uri>
              <name>Gazebo/Grey</name>
            </script>
          </material>
        </visual>
        <self_collide>0</self_collide>
        <enable_wind>0</enable_wind>
        <kinematic>0</kinematic>
      </link>
    </model>

    <!-- 物理与环境参数 -->
    <gravity>0 0 -9.8</gravity>
    <magnetic_field>6e-06 2.3e-05 -4.2e-05</magnetic_field>
    <atmosphere type='adiabatic'/>
    <physics name='default_physics' default='0' type='ode'>
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1</real_time_factor>
      <real_time_update_rate>1000</real_time_update_rate>
    </physics>
    <scene>
      <ambient>0.4 0.4 0.4 1</ambient>
      <background>0.7 0.7 0.7 1</background>
      <shadows>1</shadows>
    </scene>
    
      <device>default</device>
    
    <wind/>
    <spherical_coordinates>
      <surface_model>EARTH_WGS84</surface_model>
      <latitude_deg>0</latitude_deg>
      <longitude_deg>0</longitude_deg>
      <elevation>0</elevation>
      <heading_deg>0</heading_deg>
    </spherical_coordinates>

    <!-- ============================================== -->
    <!-- 6x8机器人对抗竞技场 - 完全空旷版 v1.0 -->
    <!-- 内部可玩区域：X轴(-3m ~ +3m)，Y轴(-4m ~ +4m) -->
    <!-- 设计理念：纯粹的开放空间，无任何内部障碍物 -->
    <!-- 适用场景：基础移动测试、速度测试、导航算法、简单追逐对抗 -->
    <!-- ============================================== -->
    <model name='arena_6x8'>
      <pose frame=''>0 0 0 0 0 0</pose>

      <!-- ============================================== -->
      <!-- 边界墙体 - 定义竞技场范围 -->
      <!-- 所有边界墙厚度0.15m，高度0.3m -->
      <!-- 边界墙使用白色材质，便于视觉识别 -->
      <!-- ============================================== -->
      
      <!-- 北边界墙 (Y=+4.075m) -->
      <link name='Boundary_Wall_North'>
        <collision name='Boundary_Wall_North_Collision'>
          <geometry><box><size>6.0 0.15 0.3</size></box></geometry>
          <pose frame=''>0 0 0.15 0 0 0</pose>
        </collision>
        <visual name='Boundary_Wall_North_Visual'>
          <pose frame=''>0 0 0.15 0 0 0</pose>
          <geometry><box><size>6.0 0.15 0.3</size></box></geometry>
          <material>
            <script>
              <uri>file://media/materials/scripts/gazebo.material</uri>
              <name>Gazebo/White</name>
            </script>
          </material>
        </visual>
        <pose frame=''>0 4.075 0 0 0 0</pose>
      </link>

      <!-- 南边界墙 (Y=-4.075m) -->
      <link name='Boundary_Wall_South'>
        <collision name='Boundary_Wall_South_Collision'>
          <geometry><box><size>6.0 0.15 0.3</size></box></geometry>
          <pose frame=''>0 0 0.15 0 0 0</pose>
        </collision>
        <visual name='Boundary_Wall_South_Visual'>
          <pose frame=''>0 0 0.15 0 0 0</pose>
          <geometry><box><size>6.0 0.15 0.3</size></box></geometry>
          <material>
            <script>
              <uri>file://media/materials/scripts/gazebo.material</uri>
              <name>Gazebo/White</name>
            </script>
          </material>
        </visual>
        <pose frame=''>0 -4.075 0 0 0 0</pose>
      </link>

      <!-- 东边界墙 (X=+3.075m) -->
      <link name='Boundary_Wall_East'>
        <collision name='Boundary_Wall_East_Collision'>
          <geometry><box><size>0.15 8.0 0.3</size></box></geometry>
          <pose frame=''>0 0 0.15 0 0 0</pose>
        </collision>
        <visual name='Boundary_Wall_East_Visual'>
          <pose frame=''>0 0 0.15 0 0 0</pose>
          <geometry><box><size>0.15 8.0 0.3</size></box></geometry>
          <material>
            <script>
              <uri>file://media/materials/scripts/gazebo.material</uri>
              <name>Gazebo/White</name>
            </script>
          </material>
        </visual>
        <pose frame=''>3.075 0 0 0 0 0</pose>
      </link>

      <!-- 西边界墙 (X=-3.075m) -->
      <link name='Boundary_Wall_West'>
        <collision name='Boundary_Wall_West_Collision'>
          <geometry><box><size>0.15 8.0 0.3</size></box></geometry>
          <pose frame=''>0 0 0.15 0 0 0</pose>
        </collision>
        <visual name='Boundary_Wall_West_Visual'>
          <pose frame=''>0 0 0.15 0 0 0</pose>
          <geometry><box><size>0.15 8.0 0.3</size></box></geometry>
          <material>
            <script>
              <uri>file://media/materials/scripts/gazebo.material</uri>
              <name>Gazebo/White</name>
            </script>
          </material>
        </visual>
        <pose frame=''>-3.075 0 0 0 0 0</pose>
      </link>

      <static>1</static>
    </model>

    <!-- GUI相机初始位置 - 俯视整个竞技场 -->
    <gui fullscreen='0'>
      <camera name='user_camera'>
        <pose frame=''>-10 0 8 0 0.4 0</pose>
        <view_controller>orbit</view_controller>
        <projection_type>perspective</projection_type>
      </camera>
    </gui>
  </world>
</sdf>